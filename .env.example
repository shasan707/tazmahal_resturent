# OPENAI_API_KEY: Required for the chat widget (gpt-4o-mini).
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# RETELL_API_KEY: Required for the voice widget and the setup script.
RETELL_API_KEY="MY_RETELL_API_KEY"

# RETELL_AGENT_ID: Produced by `npm run setup:retell`. Used to mint web-call tokens.
RETELL_AGENT_ID="MY_RETELL_AGENT_ID"

# RETELL_VOICE_ID: Used only by the setup script. Pick a voice that supports Polish
# in the Retell dashboard. Defaults to "retell-Cimo" if unset.
RETELL_VOICE_ID="retell-Cimo"

# NEXT_PUBLIC_RETELL_PHONE_NUMBER: Phone number shown in the voice widget for users
# who prefer to dial. Bind this number to the agent in the Retell dashboard.
NEXT_PUBLIC_RETELL_PHONE_NUMBER="+48 22 100 20 30"

# APP_URL: The URL where this app is hosted (self-referential links / callbacks).
APP_URL="MY_APP_URL"
